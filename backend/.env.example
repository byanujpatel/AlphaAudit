# ==============================================================================
# AlphaWeave Environment Configuration
# Duplicate this file as '.env' and fill in your keys.
# ==============================================================================

# Gemini API Key (Free tier or pay-as-you-go)
# Obtain from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Bright Data API Credentials
# These will be dynamically passed to the local Bright Data MCP Server
BRIGHT_DATA_API_KEY=your_bright_data_api_key_here
BRIGHT_DATA_CUSTOMER_ID=your_bright_data_customer_id_here

# Bright Data Zones for REST API Scraping (Fallbacks)
# Set these to your exact active zone names in the Bright Data control panel!
BRIGHT_DATA_SERP_ZONE=serp_api1
BRIGHT_DATA_WEB_UNLOCKER_ZONE=web_unlocker1

# Specific endpoints if you choose to connect manually
BRIGHT_DATA_SCRAPING_BROWSER_URL=wss://brd-customer-xxxx-zone-xxxx:password@brd.superproxy.io:9222
BRIGHT_DATA_WEB_UNLOCKER_PROXY=http://brd-customer-xxxx-zone-xxxx:password@brd.superproxy.io:22225
BRIGHT_DATA_SERP_API_KEY=your_bright_data_serp_api_key_here
